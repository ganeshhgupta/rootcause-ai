# ─── LLM ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Embeddings: Vertex AI text-embedding-004 (required) ────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=us-central1

# ─── Database: NeonDB (required) ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── LangSmith tracing ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=rootcause-ai

# ─── Upstash Redis Streams (required, replaces Pub/Sub) ─────────────────────
UPSTASH_REDIS_URL=rediss://default:your_token@your-endpoint.upstash.io:6379

# ─── Network simulator ──────────────────────────────────────────────────────
SIMULATOR_URL=http://localhost:8001

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── HITL threshold ─────────────────────────────────────────────────────────
ANOMALY_HITL_THRESHOLD=0.8

# ─── CORS (comma-separated, lock to Vercel domain in production) ────────────
ALLOWED_ORIGINS=http://localhost:3000
